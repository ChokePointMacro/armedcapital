#!/bin/zsh
cd ~/Desktop/armedcapital-push
python3 -c "
import base64,gzip
r=b''
c=b''
open('src/app/api/studio/youtube/route.ts','wb').write(gzip.decompress(base64.b64decode(r)))
open('src/components/YouTubeShorts.tsx','wb').write(gzip.decompress(base64.b64decode(c)))
print('Both files deployed successfully')
"

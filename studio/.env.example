# Studio Service Configuration
# Copy this to .env and fill in your values

# LLM Provider: "ollama" or "claude"
LLM_PROVIDER=ollama

# Ollama (local) — free, no key needed
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Claude API — requires Anthropic API key
ANTHROPIC_API_KEY=

# Image Generation (Gemini)
GEMINI_API_KEY=

# Speech-to-Text: "local_whisper" or "assemblyai"
STT_PROVIDER=local_whisper
ASSEMBLYAI_API_KEY=

# Chrome profile (must be pre-logged into YouTube + X.com)
# macOS: ~/Library/Application Support/Google/Chrome
# Linux: ~/.config/google-chrome
# Windows: %LOCALAPPDATA%\Google\Chrome\User Data
CHROME_PROFILE_DIR=
CHROME_PROFILE_NAME=Default

# ImageMagick binary path
# Linux: /usr/bin/convert
# macOS (Homebrew ARM): /opt/homebrew/bin/magick
# macOS (Homebrew Intel): /usr/local/bin/magick
# Windows: C:\Program Files\ImageMagick-7\magick.exe
IMAGEMAGICK_PATH=/usr/bin/convert

# Studio API
STUDIO_API_PORT=8100
STUDIO_API_HOST=0.0.0.0

# Post Bridge (optional — cross-post to TikTok/Instagram)
POST_BRIDGE_API_KEY=
POST_BRIDGE_ENABLED=false
